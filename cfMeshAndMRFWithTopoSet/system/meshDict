//     {
//         keepCells 1;
//     }
// }

// メッシュ生成時に cellZone まで付けたい場合は cellZones ブロック等を参照（topoSet と二重にしないこと）。
// cellZones
// {
//     rotor
//     {
//         type            surface;
//         surfaceFile     "mrf_geometry.stl";
//         selectionMode   inside;
//     }
// }

// 入力表面（cadouter.fms）のパッチ名に対応。ここに無いパッチ付近は maxCellSize 側に寄りやすい。
localRefinement
{
    inlet
    {
        cellSize 0.01;
    }
    outlet
    {
        cellSize 0.01;
    }
    wall
    {
        cellSize 0.01;
    }
    mrf_outer
    {
        cellSize 0.01;
    }
    rot
    {
        cellSize 0.01;
    }
    bottom
    {
        cellSize 0.01;
    }
}
 

FoamFile
{
    version   2.0;
    format    ascii;
    class     dictionary;
    location  "system";
    object    meshDict;
}

// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

surfaceFile "cadouter.fms";

maxCellSize 0.2;

boundaryCellSize 0.1;

/* keepCellsIntersectingPatches
{

    }
}  */

keepCellsIntersectingBoundary 1;

localRefinement
{
    inlet
    {
        cellSize 0.01;
    }
    outlet
    {
        cellSize 0.01;
    }
    wall
    {
        cellSize 0.01;
    }
    mrf_outer
    {
        cellSize 0.01;
    }
}
 

FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      changeDictionaryDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

boundary
{
    bottom
    {
        type            wall;
        inGroups        1(bottom);
    }
    inlet
    {
        type            patch;
        inGroups        1(inlet);
    }
    mrf_outer
    {
        type            cyclicAMI;
        neighbourPatch  mrf_inner;
    }
    wall
    {
        type            wall;
        inGroups        1(wall);
    }
    outlet
    {
        type            patch;
        inGroups        1(outlet);
    }
    rot
    {
        type            wall;
        inGroups        1(rot);
    }
    mrf_inner
    {
        type            cyclicAMI;
        neighbourPatch  mrf_outer;
    }
}